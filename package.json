{
  "name": "tedxcuneo",
  "type": "module",
  "version": "2.0.2",
  "scripts": {
    "prepare": "husky",
    "cf-codegen": "eval $(grep '^CONTENTFUL_SPACE_ID' .env) && eval $(grep '^CONTENTFUL_MGMT_TOKEN' .env) && cf-content-types-generator -s ${CONTENTFUL_SPACE_ID} -t ${CONTENTFUL_MGMT_TOKEN} --typeguard -o src/lib/generated/contentful -p  --v10 --jsdoc --preserve",
    "dev": "astro dev --host",
    "start": "astro dev",
    "build": "astro check && astro build",
    "astro": "astro",
    "clean": "git clean --interactive -dx --exclude .env.example --exclude \".env.*.example\" --exclude node_modules/ --exclude .husky/",
    "lint": "npm-run-all --parallel lint:astro lint:js+ts lint:format lint:types",
    "lint:astro": "astro check",
    "lint:js+ts": "eslint --ext .astro,.js,.jsx,.cjs,.ts,.tsx,.cts --ignore-path .gitignore .",
    "lint:format": "prettier --check src/**",
    "lint:types": "tsc --noEmit",
    "lint:fix": "npm-run-all --serial lint:fix:*",
    "lint:fix:js+ts": "npm run lint:js+ts --fix",
    "lint:fix:format": "prettier --write ."
  },
  "lint-staged": {
    "*.{js,ts,astro}": [
      "astro check",
      "eslint --fix",
      "prettier --ignore-unknown --write"
    ],
    "*.{json,md}": [
      "prettier  --ignore-unknown --write"
    ]
  },
  "dependencies": {
    "@astrojs/check": "^0.5.10",
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.1.1",
    "@astrojs/tailwind": "^5.1.5",
    "@contentful/rich-text-html-renderer": "^16.6.10",
    "@tailwindcss/nesting": "^0.0.0-insiders.565cd3e",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^4.16.19",
    "astro-robots-txt": "^1.0.0",
    "cf-content-types-generator": "^2.16.1",
    "contentful": "^10.15.1",
    "motion": "^12.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sitemap": "^7.1.1",
    "swiper": "^11.2.10",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@typescript-eslint/eslint-plugin": "7.3.1",
    "chalk": "^5.6.2",
    "eslint": "8.57.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-airbnb-typescript": "18.0.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-import-resolver-typescript": "3.6.1",
    "eslint-plugin-astro": "^0.32.0",
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-regexp": "2.3.0",
    "eslint-plugin-simple-import-sort": "12.0.0",
    "eslint-plugin-tailwindcss": "3.15.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "nano-staged": "^0.8.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.13.0",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "sass": "^1.98.0",
    "typescript": "^5.9.3"
  }
}
